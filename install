#!/usr/bin/env python3
import argparse
import os
import socket
import sys
from datetime import datetime
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover - Python < 3.11
    tomllib = None

ROOT = Path(__file__).resolve().parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from dotfiles_installer.apply import apply_entry
from dotfiles_installer.codex_config import apply_codex_config
from dotfiles_installer.codex_config import plan_codex_config
from dotfiles_installer.context import detect_context
from dotfiles_installer.manifest import ManifestEntry
from dotfiles_installer.manifest import load_manifest
from dotfiles_installer.planner import build_plan_report
from dotfiles_installer.reporting import (
    read_text_if_exists,
    render_text_diff,
    summarize_generated_line,
    summarize_overridden_line,
    summarize_plan_line,
    summarize_run,
)


def _matches_only(entry: ManifestEntry, only: str | None) -> bool:
    if not only:
        return True
    return only in entry.target or only in entry.source


def _resolve_host_name(explicit: str | None) -> str:
    return explicit or socket.gethostname()


def _matches_codex_only(only: str | None) -> bool:
    if not only:
        return True
    candidates = (
        "config/codex/config.public.toml",
        "config/codex/config.private.toml",
        "~/.codex/config.toml",
        "codex",
    )
    return any(only in candidate for candidate in candidates)


def _resolve_repo_root(
    entry: ManifestEntry,
    *,
    base_root: Path,
    private_root: Path | None,
    host_root: Path | None,
) -> Path:
    if entry.layer == "private":
        if private_root is None:
            raise ValueError("private entry requested without private root")
        return private_root
    if entry.layer == "host":
        if host_root is None:
            raise ValueError("host entry requested without host root")
        return host_root
    return base_root


def _file_mode(path: Path) -> int | None:
    if not path.exists():
        return None
    return path.stat().st_mode & 0o777


def _render_entry_preview(entry, repo_root: Path, *, dry_run: bool) -> tuple[bool, str | None]:
    source_path = repo_root / entry.source
    target_path = Path(entry.target).expanduser()
    source_text = source_path.read_text(encoding="utf-8")
    current_text = read_text_if_exists(target_path)
    current_mode = _file_mode(target_path)
    desired_mode = int(entry.mode, 8)
    content_matches = current_text == source_text
    mode_matches = current_mode == desired_mode
    needs_change = not (content_matches and mode_matches)

    if dry_run:
        status = "nochange" if not needs_change else "would apply"
        return needs_change, f"{status}: {summarize_plan_line(entry)}"

    lines = [summarize_plan_line(entry)]
    if not needs_change:
        lines.append("No changes needed")
        return needs_change, "\n".join(lines)

    lines.append(render_text_diff(entry.target, entry.source, current_text, source_text))
    if current_text is not None and content_matches and not mode_matches:
        lines.append(f"Mode change: {current_mode:04o} -> {desired_mode:04o}")
    return needs_change, "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--context", choices=("local", "remote"))
    parser.add_argument("--private")
    parser.add_argument("--hosts")
    parser.add_argument("--host-name")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--only")
    parser.add_argument("--yes", action="store_true")
    args = parser.parse_args()

    if args.host_name and not args.hosts:
        parser.error("--host-name requires --hosts")

    context = detect_context(args.context, dict(os.environ))
    entries = load_manifest(ROOT / "manifest" / "base.tsv", "base")
    private_root = None
    host_root = None
    if args.private:
        private_root = Path(args.private).expanduser()
        entries += load_manifest(private_root / "manifest" / "private.tsv", "private")
    if args.hosts:
        host_root = Path(args.hosts).expanduser()
        resolved_host = _resolve_host_name(args.host_name)
        host_manifest = host_root / "manifest" / f"{resolved_host}.tsv"
        if not host_manifest.exists():
            parser.error(f"Host manifest not found: {host_manifest}")
        entries += load_manifest(host_manifest, "host")
    codex_plan = None
    if _matches_codex_only(args.only):
        try:
            codex_plan = plan_codex_config(ROOT, private_root)
        except ValueError as exc:
            parser.error(str(exc))
        except Exception as exc:
            if tomllib is not None and isinstance(exc, tomllib.TOMLDecodeError):
                parser.error(f"Generated Codex config is not valid TOML: {exc}")
            raise
    report = build_plan_report(entries, context=context)
    filtered_plan = {
        target: entry
        for target, entry in report.selected.items()
        if _matches_only(entry, args.only)
    }
    filtered_overridden: list[ManifestEntry] = []
    for _, overridden_entries in report.overridden.items():
        for entry in overridden_entries:
            if _matches_only(entry, args.only):
                filtered_overridden.append(entry)

    backup_root = Path.home() / ".dotfiles-backup" / datetime.now().strftime("%Y%m%d-%H%M%S")
    applied = 0
    skipped = 0
    nochange = 0
    for entry in filtered_plan.values():
        repo_root = _resolve_repo_root(entry, base_root=ROOT, private_root=private_root, host_root=host_root)
        needs_change, preview = _render_entry_preview(entry, repo_root=repo_root, dry_run=args.dry_run)
        print(preview)
        if not needs_change:
            nochange += 1
            continue
        if args.dry_run:
            continue
        apply_current = True
        if not args.yes:
            while True:
                answer = input("Apply this change? [y]es/[n]o/[q]uit/[a]ll: ").strip().lower()
                if answer == "y":
                    break
                if answer == "n":
                    apply_current = False
                    break
                if answer == "q":
                    print(summarize_run(applied, skipped, nochange, len(filtered_overridden), args.dry_run))
                    return 1
                if answer == "a":
                    args.yes = True
                    break
        if not apply_current:
            skipped += 1
            continue
        apply_entry(entry, repo_root=repo_root, backup_root=backup_root)
        applied += 1
    if codex_plan is not None:
        codex_status = apply_codex_config(codex_plan, backup_root=backup_root, dry_run=args.dry_run)
        print(
            summarize_generated_line(
                "codex",
                codex_plan.source_label,
                codex_plan.target_label,
                status=codex_status.replace("_", " "),
            )
        )
        if codex_status == "applied":
            applied += 1
        if codex_status == "nochange":
            nochange += 1
    for entry in filtered_overridden:
        if args.dry_run:
            print(summarize_overridden_line(entry))
    print(summarize_run(applied, skipped, nochange, len(filtered_overridden), args.dry_run))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
